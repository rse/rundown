{
    "compilerOptions": {
        "outDir":                  "../dst",
        "target":                  "ESNext",
        "module":                  "ESNext",
        "moduleResolution":        "Bundler",
        "useDefineForClassFields": true,
        "composite":               false,
        "strict":                  true,
        "jsx":                     "preserve",
        "resolveJsonModule":       true,
        "isolatedModules":         true,
        "verbatimModuleSyntax":    true,
        "noImplicitThis":          true,
        "esModuleInterop":         true,
        "lib":                     [ "ESNext", "DOM" ],
        "skipLibCheck":            true,
        "noEmit":                  true,
        "types":                   [ "vite/client" ],
        "baseUrl":                 ".",
        "paths": {
            "rundown-3-lib":       [ "../../rundown-3-lib/src/rundown.ts" ]
        }
    },
    "include": [
        "../src/**/*.d.ts",
        "../src/**/*.ts",
        "../src/**/*.vue"
    ],
    "references": [
        { "path": "./tsc.node.json" }
    ]
}
